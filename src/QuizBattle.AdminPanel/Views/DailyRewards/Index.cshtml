@model QuizBattle.AdminPanel.Models.DailyRewardListViewModel

@{
    ViewData["Title"] = "جایزه روزانه";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">جایزه روزانه</h5>
        <div>
            <a class="btn btn-success me-2" asp-action="Create">افزودن جایزه جدید</a>
            <a class="btn btn-primary" asp-action="Index">لیست جوایز</a>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>روز</th>
                        <th>سکه</th>
                        <th>جایزه ویژه</th>
                        <th>فعال</th>
                        <th class="text-end">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reward in Model.Rewards)
                    {
                        <tr>
                            <td>@reward.Day</td>
                            <td>+@reward.CoinReward</td>
                            <td>@(string.IsNullOrWhiteSpace(reward.SpecialReward) ? "-" : reward.SpecialReward)</td>
                            <td>
                                @if (reward.IsActive)
                                {
                                    <span class="badge bg-success">فعال</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">غیرفعال</span>
                                }
                            </td>
                            <td class="text-end">
                                <form asp-action="ToggleActive" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@reward.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary me-1">
                                        @(reward.IsActive ? "غیرفعال" : "فعال")
                                    </button>
                                    @Html.AntiForgeryToken()
                                </form>
                                <form asp-action="Delete" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@reward.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger me-1" onclick="return confirm('آیا مطمئن هستید که می‌خواهید این جایزه را حذف کنید؟');">
                                        حذف
                                    </button>
                                    @Html.AntiForgeryToken()
                                </form>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@reward.Id">ویرایش</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
