@model QuizBattle.AdminPanel.Models.ReportedQuestionListViewModel
@{
    ViewData["Title"] = "سوالات گزارش شده";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">سوالات گزارش شده</h4>
        <small class="text-muted">سوالاتی که توسط کاربران گزارش شده‌اند</small>
    </div>
</div>

@if (Model.Reports.Any())
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th width="60">#</th>
                            <th>متن سوال</th>
                            <th width="120">دسته‌بندی</th>
                            <th width="150">تاریخ گزارش</th>
                            <th width="150">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var report in Model.Reports)
                        {
                            <tr>
                                <td>@report.QuestionId</td>
                                <td>@report.QuestionText</td>
                                <td><span class="badge bg-secondary">@report.CategoryName</span></td>
                                <td>@report.ReportedAt.ToString("yyyy/MM/dd HH:mm")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-controller="Questions" asp-action="Edit" asp-route-id="@report.QuestionId" 
                                           class="btn btn-outline-primary" title="ویرایش">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="ClearReports" method="post" style="display: inline;">
                                            <input type="hidden" name="id" value="@report.QuestionId" />
                                            <button type="submit" class="btn btn-outline-success" title="تایید">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                        <button type="button" class="btn btn-outline-danger" title="حذف سوال"
                                                onclick="confirmDelete(@report.QuestionId)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Reported" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
else
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-check-circle text-success" style="font-size: 64px;"></i>
            <h5 class="mt-3">هیچ سوال گزارش شده‌ای وجود ندارد</h5>
            <p class="text-muted">همه چیز رو به راه است!</p>
        </div>
    </div>
}

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">حذف سوال</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                آیا از حذف این سوال مطمئن هستید؟
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">انصراف</button>
                <form asp-controller="Questions" asp-action="Delete" method="post" id="deleteForm">
                    <input type="hidden" name="id" id="deleteQuestionId" />
                    <button type="submit" class="btn btn-danger">حذف</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id) {
            document.getElementById('deleteQuestionId').value = id;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}
