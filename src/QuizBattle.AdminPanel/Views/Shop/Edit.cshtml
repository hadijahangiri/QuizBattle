@model QuizBattle.AdminPanel.Models.EditStoreItemViewModel
@{
    ViewData["Title"] = "ویرایش بسته سکه";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">ویرایش بسته سکه</h4>
        <small class="text-muted">@Model.Name</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right me-1"></i> بازگشت
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" placeholder="مثال: بسته برنزی" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label asp-for="CoinAmount" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="CoinAmount" class="form-control" type="number" min="1" />
                                <span class="input-group-text">🪙 سکه</span>
                            </div>
                            <span asp-validation-for="CoinAmount" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PriceInToman" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="PriceInToman" class="form-control" type="number" min="1000" step="1000" />
                                <span class="input-group-text">تومان</span>
                            </div>
                            <span asp-validation-for="PriceInToman" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label asp-for="DiscountPercent" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="DiscountPercent" class="form-control" type="number" min="0" max="100" />
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="DiscountPercent" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="2" 
                                  placeholder="توضیحات کوتاه درباره این بسته..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="OrderIndex" class="form-label"></label>
                            <input asp-for="OrderIndex" class="form-control" type="number" min="0" />
                            <small class="text-muted">عدد کمتر = نمایش زودتر</small>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label class="form-label d-block">&nbsp;</label>
                            <div class="form-check form-switch">
                                <input asp-for="IsPopular" class="form-check-input" type="checkbox" />
                                <label asp-for="IsPopular" class="form-check-label">
                                    نشان محبوب 🔥
                                </label>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary">انصراف</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> ذخیره تغییرات
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
