@model QuizBattle.AdminPanel.Models.UserViewModel
@{
    ViewData["Title"] = $"کاربر: {Model.Username}";
}

<div class="row">
    <div class="col-md-4">
        <!-- User Card -->
        <div class="card">
            <div class="card-body text-center">
                <img src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? $"https://api.dicebear.com/7.x/avataaars/svg?seed={Model.Username}" : Model.AvatarUrl)" 
                     class="rounded-circle mb-3" width="100" height="100">
                <h4>@Model.Username</h4>
                <span class="badge bg-primary mb-3">سطح @Model.Level</span>
                
                <div class="d-flex justify-content-center gap-2 mt-3">
                    <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger") fs-6">
                        @(Model.IsActive ? "فعال" : "بن شده")
                    </span>
                </div>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between">
                    <span>ایمیل</span>
                    <span>@(Model.Email ?? "-")</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span>تلفن</span>
                    <span>@(Model.PhoneNumber ?? "-")</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span>تاریخ عضویت</span>
                    <span>@Model.CreatedAt.ToString("yyyy/MM/dd")</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span>آخرین ورود</span>
                    <span>@(Model.LastLoginAt?.ToString("yyyy/MM/dd HH:mm") ?? "-")</span>
                </li>
            </ul>
            <div class="card-footer">
                <div class="d-grid gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="bi bi-pencil me-1"></i> ویرایش
                    </a>
                    <form asp-action="ToggleActive" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn @(Model.IsActive ? "btn-warning" : "btn-success") w-100">
                            <i class="bi bi-@(Model.IsActive ? "slash-circle" : "check-circle") me-1"></i>
                            @(Model.IsActive ? "بن کردن" : "فعال کردن")
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <!-- Stats -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h3 class="mb-0 text-warning">🪙 @Model.Coins.ToString("N0")</h3>
                        <small class="text-muted">سکه</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h3 class="mb-0 text-primary">@Model.TotalGames</h3>
                        <small class="text-muted">کل بازی‌ها</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h3 class="mb-0 text-success">@Model.TotalWins</h3>
                        <small class="text-muted">برد</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h3 class="mb-0 text-danger">@Model.TotalLosses</h3>
                        <small class="text-muted">باخت</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="card">
            <div class="card-header">عملیات‌ها</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <h6>اضافه کردن سکه</h6>
                        <form asp-action="AddCoins" method="post" class="input-group">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="number" name="amount" class="form-control" placeholder="تعداد سکه" value="100">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-plus-lg"></i> اضافه
                            </button>
                        </form>
                    </div>
                    <div class="col-md-6">
                        <h6>ریست آمار</h6>
                        <form asp-action="ResetStats" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-warning w-100" 
                                    onclick="return confirm('آیا مطمئن هستید؟')">
                                <i class="bi bi-arrow-counterclockwise me-1"></i> ریست آمار برد/باخت
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-right me-1"></i> بازگشت به لیست
    </a>
</div>
