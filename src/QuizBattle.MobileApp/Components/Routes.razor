<Router AppAssembly="typeof(MauiProgram).Assembly" AdditionalAssemblies="@(new[] { typeof(QuizBattle.Shared.AppState).Assembly })" NotFoundPage="typeof(QuizBattle.Shared.Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(QuizBattle.Shared.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
