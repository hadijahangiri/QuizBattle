    private bool? GetOpponentAnswerStatus(RoundQuestionDto? rq)
    {
        if (rq == null || game == null) return null;
        var isPlayer1 = game.Player1Id == AppState.CurrentUserId;
        // حریف = بازیکن مقابل
        if (isPlayer1)
            return rq.Player2IsCorrect;
        else
            return rq.Player1IsCorrect;
    }

    private bool? GetOpponentAnswerForOption(Guid answerId)
    {
        // فقط وقتی نشان بده که حریف قبلاً جواب داده باشد
        var rq = GetCurrentRoundQuestion();
        if (rq == null || game == null) return null;

        var isPlayer1 = game.Player1Id == AppState.CurrentUserId;
        var opponentIsCorrect = isPlayer1 ? rq.Player2IsCorrect : rq.Player1IsCorrect;
        if (opponentIsCorrect == null) return null; // حریف هنوز جواب نداده

        // اگر حریف این گزینه رو انتخاب کرده و ما جواب صحیح رو میدونیم
        // فقط با نقطه سبز/قرمز نشان بده
        if (answerId == correctAnswerId && opponentIsCorrect == true) return true;
        // TODO: need opponent's actual selected answer ID from backend for precise display
        return null;
    }

