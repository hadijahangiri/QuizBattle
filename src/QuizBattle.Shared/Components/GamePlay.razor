@using System.Timers
@using Microsoft.Extensions.Logging
@inject HttpClient Http
@inject AppState AppState
@inject ILogger<GamePlay> Logger

<div class="qok-game-container">
    <div class="qok-main">
        <div class="qok-battle-header">
            <div class="qok-battle-title-box">
                <span class="qok-battle-title">نبرد تن به تن</span>
                <button class="qok-header-back-btn" @onclick="GoBack" aria-label="بازگشت">
                    <span>→</span>
                </button>
            </div>
        </div>

    @if (isLoading)
    {
        <div class="loading">
            <div class="spinner"></div>
        </div>
    }
    else if (game == null)
    {
        <p>بازی یافت نشد</p>
    }
    else if (showPostAnswer && currentQuestion != null)
    {
        <!-- صفحه بعد از پاسخ دادن -->
        <div class="question-container post-answer-container">
            <div class="game-header">
                <div class="round-info">راند @(currentRound?.RoundNumber ?? 0) - سوال @currentQuestionIndex/@totalQuestions</div>
                <div class="post-answer-badge @(lastAnswerCorrect ? "correct" : "wrong")">
                    @(lastAnswerCorrect ? "✅ صحیح" : "❌ غلط")
                    @if (lastAnswerCorrect && lastAnswerScore > 0)
                    {
                        <span class="score-earned">+@lastAnswerScore</span>
                    }
                </div>
            </div>

            <div class="question post-answer-question">
                <p class="question-text">@currentQuestion.Text</p>
            </div>

            <!-- نمایش پاسخ‌ها با نتیجه -->
            <div class="answers">
                @foreach (var answer in currentQuestion.Answers)
                {
                    var cls = GetPostAnswerClass(answer.Id);
                    <div class="answer-result-row @cls">
                        <span>@answer.Text</span>
                        @if (answer.Id == correctAnswerId)
                        {
                            <span class="answer-indicator correct-indicator">✅</span>
                        }
                        else if (answer.Id == selectedAnswer)
                        {
                            <span class="answer-indicator wrong-indicator">❌</span>
                        }
                    </div>
                }
            </div>

            <!-- نمایش پاسخ حریف -->
            @{
                var rq = GetCurrentRoundQuestion();
                var opponentAnswered = GetOpponentAnswerStatus(rq);
            }
            @if (opponentAnswered != null)
            {
                <div class="opponent-answer-status @(opponentAnswered.Value ? "opponent-correct" : "opponent-wrong")">
                    <span>@GetLeftPlayerUsername():</span>
                    <span>@(opponentAnswered.Value ? "✅ درست" : "❌ غلط")</span>
                </div>
            }

            <!-- پیام موفقیت لایک/دیسلایک -->
            @if (reactionFeedback != null)
            {
                <div class="reaction-feedback-message">@reactionFeedback</div>
            }

            <!-- دکمه‌های عملیات -->
            <div class="post-answer-actions">
                <button class="action-btn like @(userReaction == 1 ? "active" : "")" @onclick="LikeQuestion" disabled="@(userReaction != 0)">
                    <span class="action-icon">👍</span> <span>لایک</span>
                </button>
                <button class="action-btn dislike @(userReaction == 2 ? "active" : "")" @onclick="DislikeQuestion" disabled="@(userReaction != 0)">
                    <span class="action-icon">👎</span> <span>دیسلایک</span>
                </button>
                <button class="action-btn report @(reportSubmitted ? "reported" : "")" @onclick="OpenReportModal" disabled="@reportSubmitted">
                    <span class="action-icon">🚩</span> <span>@(reportSubmitted ? "گزارش شد" : "گزارش")</span>
                </button>
            </div>

            <button class="btn btn-primary btn-next-question" @onclick="GoToNextQuestion">
                @if (currentQuestionIndex >= totalQuestions)
                {
                    <span>پایان راند ➡️</span>
                }
                else
                {
                    <span>سوال بعدی ➡️</span>
                }
            </button>
        </div>

        <!-- مدال گزارش -->
        @if (showReportModal)
        {
            <div class="qok-modal-overlay" @onclick="CloseReportModal">
                <div class="qok-modal report-modal" @onclick:stopPropagation="true">
                    <div class="qok-modal-header">
                        <h3>گزارش سوال</h3>
                        <button class="qok-modal-close" @onclick="CloseReportModal">✕</button>
                    </div>
                    <div class="qok-modal-body">
                        <p class="report-description">لطفاً دلیل گزارش خود را انتخاب کنید:</p>
                        <div class="report-options">
                            @foreach (var reason in reportReasons)
                            {
                                <button class="report-option-btn @(selectedReportReason == reason ? "selected" : "")"
                                        @onclick="@(() => selectedReportReason = reason)">
                                    @reason
                                </button>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(selectedReportReason))
                        {
                            <button class="btn btn-danger btn-submit-report" @onclick="SubmitReport">
                                ارسال گزارش
                            </button>
                        }
                        @if (reportSubmitted)
                        {
                            <div class="report-success">✅ گزارش شما ثبت شد. با تشکر!</div>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else if (currentQuestion != null)
    {
        <!-- سوال فعلی -->
        <div class="question-container">
            <div class="game-header">
                <div class="round-info">راند @(currentRound?.RoundNumber ?? 0) - سوال @currentQuestionIndex/@totalQuestions</div>
                <div class="game-header-avatar-wrap @(countdownExpired ? "explode" : "")">
                    <svg class="game-header-countdown-svg" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                        <circle class="countdown-track" cx="50" cy="50" r="44" />
                        <circle class="countdown-arc-halo" cx="50" cy="50" r="44"
                            style="stroke-dasharray:@GetArcCircumference();stroke-dashoffset:@GetArcDashOffset();stroke:@GetArcColor();" />
                        <circle class="countdown-arc" cx="50" cy="50" r="44"
                            style="stroke-dasharray:@GetArcCircumference();stroke-dashoffset:@GetArcDashOffset();stroke:@GetArcColor();color:@GetArcColor();" />
                        @if (!countdownExpired && GetCountdownPercent() > 1)
                        {
                            <circle class="countdown-tail-glow" cx="94" cy="50" r="12" style="fill:@GetArcColor();" />
                            <circle class="countdown-tail-core" cx="94" cy="50" r="4" style="fill:white;" />
                            <circle class="countdown-spark-outer" cx="@GetArcSparkCx()" cy="@GetArcSparkCy()" r="12" style="fill:@GetArcColor();" />
                            <circle class="countdown-spark-glow" cx="@GetArcSparkCx()" cy="@GetArcSparkCy()" r="7" style="fill:@GetArcColor();" />
                            <circle class="countdown-spark" cx="@GetArcSparkCx()" cy="@GetArcSparkCy()" r="3.5" style="fill:white;" />
                        }
                    </svg>
                    <div class="game-header-avatar">
                        @if (IsIconUrl(GetMyAvatarUrl()))
                        {
                            <img src="@GetMyAvatarUrl()" alt="شما" />
                        }
                        else if (!string.IsNullOrEmpty(GetMyAvatarUrl()))
                        {
                            <span>@GetMyAvatarUrl()</span>
                        }
                        else
                        {
                            <span>👤</span>
                        }
                    </div>
                </div>
            </div>

            <div class="question">
                @if (!string.IsNullOrEmpty(currentQuestion.ImageUrl))
                {
                    <img src="@currentQuestion.ImageUrl" class="question-image" />
                }
                <p class="question-text">@currentQuestion.Text</p>
            </div>

            <div class="answers">
                @if (currentQuestion.Answers.Any())
                {
                    @foreach (var answer in currentQuestion.Answers)
                    {
                        var answerClass = GetAnswerClass(answer.Id);
                        <button class="answer-btn @answerClass"
                                @onclick="@(() => SubmitAnswer(answer.Id))"
                                disabled="@(
                                    removedAnswers.Contains(answer.Id) ||
                                    (selectedAnswer != null && !canSelectSecondAnswer) ||
                                    (selectedAnswer != null && canSelectSecondAnswer && answer.Id == selectedAnswer)
                                )">
                            <span>@answer.Text</span>
                            @{
                                var opponentStatus = GetOpponentAnswerForOption(answer.Id);
                            }
                            @if (opponentStatus != null)
                            {
                                <span class="opponent-dot @(opponentStatus.Value ? "dot-correct" : "dot-wrong")"></span>
                            }
                        </button>
                    }
                }
                else
                {
                    <div class="no-answers">جواب‌ها در دسترس نیستند.</div>
                }
            </div>

            <div class="helpers">
                <button class="helper-btn" @onclick="UseRemoveTwoOptions" disabled="@(selectedAnswer != null || usedHelpers.Contains(1))">
                    <span class="helper-icon">❌</span>
                    <span class="helper-text">حذف دو گزینه</span>
                    <span class="helper-cost">🪙 20</span>
                </button>
                <button class="helper-btn" @onclick="UseDoubleAnswer" disabled="@(selectedAnswer != null || usedHelpers.Contains(2))">
                    <span class="helper-icon">✌️</span>
                    <span class="helper-text">دو پاسخ</span>
                    <span class="helper-cost">🪙 15</span>
                </button>
                <button class="helper-btn" @onclick="UseAddTime" disabled="@(selectedAnswer != null || usedHelpers.Contains(3))">
                    <span class="helper-icon">⏰</span>
                    <span class="helper-text">+15 ثانیه</span>
                    <span class="helper-cost">🪙 10</span>
                </button>
            </div>
        </div>
    }
    else if (showCategorySelection)
    {
        <!-- صفحه انتخاب دسته / حالت بازی قبل از شروع سوالات -->

            <!-- بخش بازیکنان -->
            <div class="qok-players-section">
                <!-- بازیکن چپ = همیشه حریف -->
                <div class="qok-player qok-player-left">
                    <div class="qok-avatar-wrapper">
                        <div class="qok-level-badge">@GetOpponentLevel()</div>
                        @if (!IsCurrentUserTurn())
                        {
                            <svg class="qok-countdown-svg @(countdownExpired ? "explode" : "")" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                                <circle class="countdown-track" cx="50" cy="50" r="44" />
                                <circle class="countdown-arc-halo" cx="50" cy="50" r="44"
                                    style="stroke-dasharray:@GetArcCircumference();stroke-dashoffset:@GetArcDashOffset();stroke:@GetArcColor();" />
                                <circle class="countdown-arc" cx="50" cy="50" r="44"
                                    style="stroke-dasharray:@GetArcCircumference();stroke-dashoffset:@GetArcDashOffset();stroke:@GetArcColor();color:@GetArcColor();" />
                                @if (!countdownExpired && GetCountdownPercent() > 1)
                                {
                                    <circle class="countdown-tail-glow" cx="94" cy="50" r="12" style="fill:@GetArcColor();" />
                                    <circle class="countdown-tail-core" cx="94" cy="50" r="4" style="fill:white;" />
                                    <circle class="countdown-spark-outer" cx="@GetArcSparkCx()" cy="@GetArcSparkCy()" r="12" style="fill:@GetArcColor();" />
                                    <circle class="countdown-spark-glow" cx="@GetArcSparkCx()" cy="@GetArcSparkCy()" r="7" style="fill:@GetArcColor();" />
                                    <circle class="countdown-spark" cx="@GetArcSparkCx()" cy="@GetArcSparkCy()" r="3.5" style="fill:white;" />
                                }
                            </svg>
                        }
                        <div class="qok-avatar">
                            @if (IsIconUrl(GetLeftPlayerAvatarUrl()))
                            {
                                <img src="@GetLeftPlayerAvatarUrl()" alt="حریف" />
                            }
                            else if (!string.IsNullOrEmpty(GetLeftPlayerAvatarUrl()))
                            {
                                <span class="qok-avatar-emoji">@GetLeftPlayerAvatarUrl()</span>
                            }
                            else
                            {
                                <span class="qok-avatar-emoji">👤</span>
                            }
                        </div>
                    </div>
                    <span class="qok-player-name">@GetLeftPlayerUsername()</span>
                </div>

                <!-- Score در وسط -->
                <div class="qok-score-center">
                    <div class="qok-score-box qok-score-left">@GetPlayerScore(false)</div>
                    <div class="qok-score-box qok-score-right">@GetPlayerScore(true)</div>
                </div>

                <!-- بازیکن راست = همیشه کاربر جاری -->
                <div class="qok-player qok-player-right">
                    <div class="qok-avatar-wrapper">
                        <div class="qok-level-badge">@AppState.Level</div>
                        @if (IsCurrentUserTurn())
                        {
                            <svg class="qok-countdown-svg @(countdownExpired ? "explode" : "")" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                                <circle class="countdown-track" cx="50" cy="50" r="44" />
                                <circle class="countdown-arc-halo" cx="50" cy="50" r="44"
                                    style="stroke-dasharray:@GetArcCircumference();stroke-dashoffset:@GetArcDashOffset();stroke:@GetArcColor();" />
                                <circle class="countdown-arc" cx="50" cy="50" r="44"
                                    style="stroke-dasharray:@GetArcCircumference();stroke-dashoffset:@GetArcDashOffset();stroke:@GetArcColor();color:@GetArcColor();" />
                                @if (!countdownExpired && GetCountdownPercent() > 1)
                                {
                                    <circle class="countdown-tail-glow" cx="94" cy="50" r="12" style="fill:@GetArcColor();" />
                                    <circle class="countdown-tail-core" cx="94" cy="50" r="4" style="fill:white;" />
                                    <circle class="countdown-spark-outer" cx="@GetArcSparkCx()" cy="@GetArcSparkCy()" r="12" style="fill:@GetArcColor();" />
                                    <circle class="countdown-spark-glow" cx="@GetArcSparkCx()" cy="@GetArcSparkCy()" r="7" style="fill:@GetArcColor();" />
                                    <circle class="countdown-spark" cx="@GetArcSparkCx()" cy="@GetArcSparkCy()" r="3.5" style="fill:white;" />
                                }
                            </svg>
                        }
                        <div class="qok-avatar">
                            @if (IsIconUrl(GetRightPlayerAvatarUrl()))
                            {
                                <img src="@GetRightPlayerAvatarUrl()" alt="شما" />
                            }
                            else if (!string.IsNullOrEmpty(GetRightPlayerAvatarUrl()))
                            {
                                <span class="qok-avatar-emoji">@GetRightPlayerAvatarUrl()</span>
                            }
                            else
                            {
                                <span class="qok-avatar-emoji">👤</span>
                            }
                        </div>
                    </div>
                    <span class="qok-player-name">@GetRightPlayerUsername()</span>
                </div>

            </div>

            <!-- تب‌ها -->
            <div class="qok-tabs">
                <button class="qok-tab @(activeTab == "chat" ? "" : "active")" @onclick='() => activeTab = "game"'>
                    مسابقه
                </button>
                <button class="qok-tab @(activeTab == "chat" ? "active" : "")" @onclick='() => activeTab = "chat"'>
                    گفت و گو
                </button>
            </div>

            @if (activeTab == "game")
            {
                <!-- محتوای بازی -->
                <div class="qok-game-content">
                    <!-- نوبت و دسته‌ها -->
                    <div class="qok-status-bar">
                        @if (!IsMyTurnToSelectCategory())
                        {
                            <div class="qok-status-item qok-turn">@GetTurnText()</div>
                        }
                        @if (IsMyTurnToSelectCategory())
                        {
                            <button class="qok-play-btn" @onclick="ShowCategoryPicker">
                                🎮 انجام بازی
                            </button>
                        }
                    </div>

                    <!-- راندها -->
                    <div class="qok-rounds">
                        @for (int i = 1; i <= totalRounds; i++)
                        {
                            var roundNum = i;
                            <div class="qok-round-row @GetRoundClass(roundNum)">
                                <div class="qok-round-result qok-round-result-left">
                                    @GetRoundResultIcon(roundNum, false)
                                </div>
                                <div class="qok-round-bar">
                                    <div class="qok-round-number">@roundNum</div>
                                </div>
                                <div class="qok-round-result qok-round-result-right">
                                    @GetRoundResultIcon(roundNum, true)
                                </div>
                            </div>
                        }
                    </div>
                </div>


            }
            else
            {
                <!-- چت -->
                <div class="qok-chat-content">
                    <p class="qok-chat-empty">پیامی وجود ندارد</p>
                </div>
            }

        <!-- مدال انتخاب موضوع -->
        @if (showingCategoryPicker)
        {
            <div class="qok-modal-overlay" @onclick="CloseCategoryPicker">
                <div class="qok-modal" @onclick:stopPropagation="true">
                    <div class="qok-modal-header">
                        <h3>موضوع راند @(game?.CurrentRound ?? 1) را انتخاب کنید</h3>
                        <button class="qok-modal-close" @onclick="CloseCategoryPicker">✕</button>
                    </div>
                    <div class="qok-modal-body">
                        @if (!string.IsNullOrEmpty(categorySelectionError))
                        {
                            <div class="qok-error-message">@categorySelectionError</div>
                        }
                        @if (categories.Any())
                        {
                            <div class="qok-categories">
                                @foreach (var category in categories)
                                {
                                    <button class="qok-category-btn" @onclick="@(() => SelectCategory(category.Id))">
                                        @if (IsIconUrl(category.IconUrl))
                                        {
                                            <img src="@category.IconUrl" alt="@category.Name" />
                                        }
                                        else if (!string.IsNullOrWhiteSpace(category.IconUrl))
                                        {
                                            <span class="qok-category-icon">@category.IconUrl</span>
                                        }
                                        else
                                        {
                                            <span class="qok-category-icon">❓</span>
                                        }
                                        <span class="qok-category-name">@category.Name</span>
                                    </button>
                                }
                            </div>
                            <button class="qok-change-btn" @onclick="ChangeCategories">
                                🔄 تغییر موضوعات ( @categoriesChangeCost سکه)
                            </button>
                        }
                        else
                        {
                            <div class="loading">
                                <div class="spinner"></div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else if (showResult)
    {
        <!-- نتیجه -->
        <div class="result-container">
            <h2>@(isWinner ? "🎉 برنده شدید!" : (isDraw ? "🤝 مساوی" : "😢 باختید"))</h2>
            <div class="final-score">
                <div class="player">
                    @if (IsIconUrl(GetMyAvatarUrl()))
                    {
                        <img src="@GetMyAvatarUrl()" alt="شما" />
                    }
                    else if (!string.IsNullOrEmpty(GetMyAvatarUrl()))
                    {
                        <span class="avatar-placeholder">@GetMyAvatarUrl()</span>
                    }
                    else
                    {
                        <span class="avatar-placeholder">👤</span>
                    }
                    <span>@myScore</span>
                </div>
                <span>-</span>
                <div class="player">
                    @if (IsIconUrl(GetLeftPlayerAvatarUrl()))
                    {
                        <img src="@GetLeftPlayerAvatarUrl()" alt="حریف" />
                    }
                    else if (!string.IsNullOrEmpty(GetLeftPlayerAvatarUrl()))
                    {
                        <span class="avatar-placeholder">@GetLeftPlayerAvatarUrl()</span>
                    }
                    else
                    {
                        <span class="avatar-placeholder">👤</span>
                    }
                    <span>@opponentScore</span>
                </div>
            </div>
            @if (isWinner)
            {
                <div class="level-progress-result">
                    @if (leveledUp)
                    {
                        <div class="level-up-banner">🎊 سطح بالا رفت! الان سطح @newLevel هستید</div>
                    }
                    else
                    {
                        <div class="level-progress-info">
                            <span class="level-num">سطح @AppState.Level</span>
                            <div class="level-progress-bar">
                                <div class="level-progress-fill"
                                     style="width: @((int)((double)AppState.WinsTowardsNextLevel / AppState.WinsNeededForNextLevel * 100))%">
                                </div>
                            </div>
                            <span class="level-progress-label">@AppState.WinsTowardsNextLevel / @AppState.WinsNeededForNextLevel برد تا سطح @(AppState.Level + 1)</span>
                        </div>
                    }
                </div>
            }
            <button class="btn btn-primary" @onclick="GoBack">بازگشت</button>
        </div>
    }
    else
    {
        <!-- انتظار برای حریف -->
        <div class="waiting">
            <div class="spinner"></div>
            <p>در انتظار نوبت حریف...</p>
            <p class="waiting-hint">حریف شما @GetGameTimeoutLabel() فرصت دارد تا نوبت خود را بازی کند.</p>
        </div>
    }
    </div>
</div>
